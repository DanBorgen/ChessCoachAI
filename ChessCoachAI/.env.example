APP_NAME="Chess Coach AI"
APP_ENV=local
APP_KEY=                        # Run: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (not used by this app, but Laravel requires a DB driver)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=chess_coach
# DB_USERNAME=root
# DB_PASSWORD=

# ─────────────────────────────────────────────
# Redis — used for caching analysis results
# ─────────────────────────────────────────────
REDIS_CLIENT=phpredis          # or 'predis' if phpredis ext not installed
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Tell Laravel to use Redis for caching
CACHE_STORE=redis
CACHE_PREFIX=chess_coach

# ─────────────────────────────────────────────
# Google Gemini API
# Get your key at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=

SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
